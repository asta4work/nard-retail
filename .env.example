MYSQL_DATABASE=retail_ops
MYSQL_USER=retail
MYSQL_PASSWORD=retail_password
MYSQL_ROOT_PASSWORD=change_root_password
COMPOSE_PROFILES=local-db
BACKEND_HOST=0.0.0.0
BACKEND_PORT=3000
BACKEND_PROXY_HOST=127.0.0.1
FRONTEND_HOST=0.0.0.0
FRONTEND_PORT=4200
DOCKER_FRONTEND_PORT=8080
DOCKER_CORS_ORIGIN=http://localhost:8080
DB_HOST=mysql
DB_PORT=3306
JWT_SECRET=replace-with-a-long-random-production-secret
JWT_EXPIRES_IN=8h
ADMIN_NAME=System Admin
ADMIN_EMAIL=admin@retail.local
ADMIN_PASSWORD=ChangeMe123!
CORS_ORIGIN=http://localhost:4200
DB_SYNCHRONIZE=true
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379
CACHE_TTL_SECONDS=60
SWAGGER_ENABLED=true
SWAGGER_PATH=docs
SWAGGER_TITLE=RetailOps API
SWAGGER_DESCRIPTION=Inventory, sales, reporting, and user management API
SWAGGER_VERSION=1.0

# Bulk demo data generated by npm run init-db
SEED_LOCALE=mixed
SEED_PRODUCT_COUNT=1000
SEED_USER_COUNT=100
SEED_SALE_COUNT=2500
SEED_BATCH_SIZE=250
